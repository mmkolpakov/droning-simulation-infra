<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Defense-in-depth beyond ROS_DOMAIN_ID + per-run Docker bridge network
  isolation: restrict the UDP transport to this container's own loopback
  and primary network interface instead of every interface on the host
  (Fast DDS's SIMPLE-profile tutorial default binds to all of them). A
  stray extra interface -- an unexpected second Docker network attached to
  a container, a host VPN/bridge device leaking through a misconfigured
  environment, etc. -- can no longer become a DDS discovery/traffic path.
  Shared memory is enabled explicitly for same-host/same-container
  participants, which is the common case for standalone smoke runs.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <transport_descriptors>
    <transport_descriptor>
      <transport_id>robotics_foundation_shm</transport_id>
      <type>SHM</type>
    </transport_descriptor>
    <transport_descriptor>
      <transport_id>robotics_foundation_udp</transport_id>
      <type>UDPv4</type>
      <interfaceWhiteList>
        <address>lo</address>
        <address>eth0</address>
      </interfaceWhiteList>
    </transport_descriptor>
  </transport_descriptors>
  <participant profile_name="robotics_foundation_participant" is_default_profile="true">
    <rtps>
      <builtin>
        <discovery_config>
          <discoveryProtocol>SIMPLE</discoveryProtocol>
          <ignoreParticipantFlags>FILTER_SAME_PROCESS</ignoreParticipantFlags>
        </discovery_config>
      </builtin>
      <useBuiltinTransports>false</useBuiltinTransports>
      <userTransports>
        <transport_id>robotics_foundation_shm</transport_id>
        <transport_id>robotics_foundation_udp</transport_id>
      </userTransports>
    </rtps>
  </participant>
</profiles>
