#!/usr/bin/env bash
set -Eeuo pipefail

if [[ ${EUID} -ne 0 ]]; then
  printf 'use-package-snapshots must run as root\n' >&2
  exit 1
fi

: "${UBUNTU_SNAPSHOT:?UBUNTU_SNAPSHOT is required}"

if [[ ! ${UBUNTU_SNAPSHOT} =~ ^[0-9]{8}T[0-9]{6}Z$ ]]; then
  printf 'Invalid Ubuntu snapshot ID: %s\n' "${UBUNTU_SNAPSHOT}" >&2
  exit 1
fi

ubuntu_sources=/etc/apt/sources.list.d/ubuntu.sources
ubuntu_archive_key=/usr/share/keyrings/ubuntu-archive-keyring.gpg
snapshot_config=/etc/apt/apt.conf.d/50robotics-snapshot
architecture="$(dpkg --print-architecture)"

case "${architecture}" in
  amd64|arm64) ;;
  *)
    printf 'Unsupported Ubuntu snapshot architecture: %s\n' "${architecture}" >&2
    exit 1
    ;;
esac

if [[ ! -f ${ubuntu_sources} ]]; then
  printf 'Ubuntu deb822 source not found: %s\n' "${ubuntu_sources}" >&2
  exit 1
fi

if [[ ! -r ${ubuntu_archive_key} ]]; then
  printf 'Ubuntu archive key not found: %s\n' "${ubuntu_archive_key}" >&2
  exit 1
fi

cat > "${ubuntu_sources}" <<EOF
Types: deb
URIs: https://snapshot.ubuntu.com/ubuntu/${UBUNTU_SNAPSHOT}
Suites: noble noble-updates noble-backports noble-security
Components: main universe restricted multiverse
Architectures: ${architecture}
Signed-By: ${ubuntu_archive_key}
EOF

printf 'APT::Update::Error-Mode "any";\nAcquire::Retries "3";\n' \
  > "${snapshot_config}"
grep -Fx "URIs: https://snapshot.ubuntu.com/ubuntu/${UBUNTU_SNAPSHOT}" \
  "${ubuntu_sources}" > /dev/null
grep -Fx "Architectures: ${architecture}" "${ubuntu_sources}" > /dev/null
apt-config dump | grep -Fx 'APT::Update::Error-Mode "any";' > /dev/null
apt-config dump | grep -Fx 'Acquire::Retries "3";' > /dev/null

if [[ -z ${ROS_SNAPSHOT:-} ]]; then
  exit 0
fi

: "${ROS_DISTRO:?ROS_DISTRO is required when ROS_SNAPSHOT is set}"
: "${ROSDISTRO_INDEX_REVISION:?ROSDISTRO_INDEX_REVISION is required when ROS_SNAPSHOT is set}"

snapshot_key=/usr/share/keyrings/ros-snapshot-key.gpg
if [[ ! -f ${snapshot_key} ]]; then
  printf 'ROS snapshot key not found: %s\n' "${snapshot_key}" >&2
  exit 1
fi

printf '%s  %s\n' \
  2917845bafcabbf651ed70e967beb61ee467ae29292288c7ccd5d7d76e5f2a2f \
  "${snapshot_key}" | sha256sum --check --status

rm -f /etc/apt/sources.list.d/ros2.sources
cat > /etc/apt/sources.list.d/ros2-snapshot.sources <<EOF
Types: deb
URIs: http://snapshots.ros.org/${ROS_DISTRO}/${ROS_SNAPSHOT}/ubuntu
Suites: noble
Components: main
Signed-By: ${snapshot_key}
EOF

rosdep_sources=/etc/ros/rosdep/sources.list.d/20-default.list
if [[ ! -f ${rosdep_sources} ]]; then
  printf 'rosdep source list not found: %s\n' "${rosdep_sources}" >&2
  exit 1
fi

sed -i \
  "s#ros/rosdistro/master#ros/rosdistro/${ROSDISTRO_INDEX_REVISION}#g" \
  "${rosdep_sources}"
grep -Fq "ros/rosdistro/${ROSDISTRO_INDEX_REVISION}" "${rosdep_sources}"
